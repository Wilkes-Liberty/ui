# See https://next-drupal.org/docs/environment-variables
# Copy to .env.local and fill in values — never commit .env.local

# Drupal backend URL
# Local: use DDEV URL  |  Docker: use internal Docker hostname
NEXT_PUBLIC_DRUPAL_BASE_URL=https://api.wilkesliberty.dev

# Domain for Next.js image optimization proxy
# Local: api.wilkesliberty.dev  |  Docker: drupal
NEXT_IMAGE_DOMAIN=api.wilkesliberty.dev

# Canonical public URL for this site (used for OpenGraph metadataBase)
NEXT_PUBLIC_SITE_URL=https://wilkesliberty.com

# OAuth2 consumer credentials (create in Drupal at /admin/config/services/consumer)
DRUPAL_CLIENT_ID=drupal-client
DRUPAL_CLIENT_SECRET=

# On-demand ISR revalidation secret (must match Drupal Next.js module config)
# Configure in Drupal at /admin/config/services/next
DRUPAL_REVALIDATE_SECRET=

# Draft/preview mode secret (must match Drupal Next.js module config)
DRUPAL_PREVIEW_SECRET=
